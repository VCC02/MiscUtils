function BadExport: Boolean; cdecl;
var
  frSimpleCOMUI: TfrSimpleCOMUI;
begin
  Application.Initialize;
  Application.CreateForm(TfrSimpleCOMUI, frSimpleCOMUI); //Probably it's ok with any form, only to link the Forms code.
  try

  finally
    frSimpleCOMUI.Free;
  end;
end;


