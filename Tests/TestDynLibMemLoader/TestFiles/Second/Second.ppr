library Second;

{$mode objfpc}{$H+}

uses
  SysUtils, Classes;

var
  FGlobalVarA: Integer;
  FGlobalVarB: Integer;


procedure SetTwoGlobalVarsStdcall(AIntA, AIntB: Integer); stdcall;
begin
  FGlobalVarA := AIntA;
  FGlobalVarB := AIntB;
end;


procedure SetTwoGlobalVarsCdecl(AIntA, AIntB: Integer); cdecl;
begin
  FGlobalVarA := AIntA;
  FGlobalVarB := AIntB;
end;


function GetAGlobalVarFromTwo(AIndex: Byte): Integer; stdcall;
begin
  case AIndex of
    0: Result := FGlobalVarA;
    1: Result := FGlobalVarB;
    else
      Result := -1;
  end;
end;


procedure HandleAnotherException(ADummyValue: Integer); cdecl;
var
  TempStream: TMemoryStream;
begin
  try
    TempStream := TMemoryStream.Create;
    try
      try
        TempStream.SetSize(3);
      finally
        TempStream.LoadFromFile('*\*');   //AV here
      end;
    finally
      TempStream.Free;
    end;
  except
    FGlobalVarA := -1;
    FGlobalVarB := -2;
  end;
end;


exports
  SetTwoGlobalVarsStdcall,
  SetTwoGlobalVarsCdecl,
  GetAGlobalVarFromTwo,
  HandleAnotherException;

begin
  FGlobalVarA := 1234567898;
  FGlobalVarB := 1234567897;
end.
